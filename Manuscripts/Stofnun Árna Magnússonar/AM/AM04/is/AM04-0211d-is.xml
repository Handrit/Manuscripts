               <head>
                  <title type="supplied">Skiptabréf og skjöl</title>
                  <title type="supplied">Um erfðir</title>
                  <origPlace>Ísland</origPlace>
                  <origDate notBefore="1650" notAfter="1700" evidence="external">s. XVII 2/2</origDate>
                  <note>Samkvæmt <ref>AM 477 fol.</ref> á <q>Regiſtur yfer Skälhollts Stiftes Preſta-garda</q> að vera í AM 211 4to, en er þar ekki nú.</note>
               </head>

               <!-- Skiptabréf frá 16.-17. öld (1-13) og blað úr ritgerð Arngríms lærða um erfðir (15-16) frá síðari hluta 17. aldar ásamt meðmælum amtmanns til prestsekkju frá 1696 (14). Upprunalegt blaðatal 56-63. Blaðið úr ritgerð Arngríms kemur framan við bl. 29r í AM 211 a 4to, með upprunalega merkingu 64. (MJ) --><msContents>
                  <textLang mainLang="da" otherLangs="is">Danska, Íslenska</textLang>
                  <msItem n="1" class="skjol embr">
                     <locus from="1r" facs="#AM04-0211d-0001r" to="7r">1r-7r</locus>
                     <title type="supplied">Skiptabréf og skjöl frá 15.-17. öld</title>
                     <note>Skiptabréfin eru 6.</note>
                  </msItem>
                  <msItem n="2" class="ordsk">
                     <locus from="7r" facs="#AM04-0211d-0007r" to="7r">7r-7r</locus>
                     <title type="supplied">Um óðalsjörð</title>
                     <note>Skilgreining.</note>
                  </msItem>
                  <msItem n="3" class="skjol">
                     <locus from="7v" facs="#AM04-0211d-0007v" to="7v">7v-7v</locus>
                     <title type="supplied">Meðmæli Christians Müllers amtmanns til prestsekkju árið 1696</title>
                     <note>Meðmæli <name key="ChrMyl01" type="person">Christians Müllers</name>eru á dönsku.</note>
                  </msItem>
                  <msItem n="4" defective="true" class="logfr ritg">
