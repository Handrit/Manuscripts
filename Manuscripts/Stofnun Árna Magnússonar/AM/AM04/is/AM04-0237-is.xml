                  <accMat>
                     <p>Fastur <locus from="accMat01r" facs="#AM04-0237-accMat01r" to="accMat01v">seðill</locus> (<dimensions type="slip" unit="mm">
                           <height>205</height>
                           <width>156</width>
                        </dimensions>) með hendi <name key="ArnMag001" type="person">Árna
                           Magnússonar</name>: <quote xml:lang="is" type="AMSlip">Originalana af
                           þessum bréfum á nú 1710 Vigfús Jónsson á Leirá, ég gaf honum þau. Þau
                           hafa fyrrum verið eign Björns Magnússonar á Munkaþverá, öll eða
                           flestöll.</quote><note> Ártalið er leiðrétt í 1711.</note></p>
                  </accMat>
               </physDesc>
