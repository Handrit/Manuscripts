						<msItem n="1" defective="true" class="uts">
							<title type="uniform">Sjónabók</title>
							<note><p>Munstrin eru límd á gömul sendibréf.</p></note>
							</msItem>
						<msItem n="2" defective="true" class="sendbr">
							<title type="supplied">Sendibréf</title>
							<note><p>Í bréfunum má finna nöfn <name type="person" key="SkuMag001">Skúla Magnússonar landfógeta</name>, <name type="person" key="BjaPal001">Bjarna Pálssonar</name> landlæknir
									og <name type="person" key="HroSig002">Hróbjarts Sigurðssonar</name> á Elliðavatni. Í bréfabrotunum er meðal annars fjallað um fjárpest og móðuharðindin þar sem má finna ártalið 1783. 
							Á þriðja aftasta blaði er ártalið <date when="1817">1718</date> og eiginhandarundirskriftir <date type="person" key="FuhNie001">Nielsar Fuhrmanns</date> amtmanns og <name type="person" key="JonTho016">Jóns Vídalíns</name> biskups.</p></note>
						</msItem>
						<msItem n="3" defective="false" class="erfikv">
							<title type="supplied">Erfiljóð um <name type="person" key="ThoGud046">Þórdísi Guðmundsdóttur</name></title>
							<author key="HelArn004">Helgi Árnason</author>
							<incipit type="upphaf">Hér er allt fallvalt í heimi …</incipit>
							<colophon>Helgi Árnason orti í orðastað Torfa Björnssonar</colophon>
							<note><p><name type="person" key="TorBjo001">Torfi Björnsson</name> var sonur Þórdísar.</p></note>
						</msItem>
