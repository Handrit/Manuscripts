                    <msContents>
                        <summary>
                            <title type="supplied">Samtíningur Jóns rektors Þorkelssonar</title>
                        </summary>
                        <textLang mainLang="is" otherLangs="da la">Íslenska, danska og latína</textLang>
                        <msItem n="1" defective="false" class="kvsk bok glosu">
                            <title type="supplied">Vísnaskýringar í Guðmundar sögu Arasonar</title>
                            <author key="JonTho009">Jón Þorkelsson</author>
                            <note><p>Athugasemdir og samtíningur Jóns lútandi að íslenskri málfræði (orðasöfn, sagnorðamyndir, orðskipunarfræði, bragreglur, vísnaskýringar),
                                    íslenskri sagnfræði og bókmenntasögu eru í alls 21 bindi undir safnmörkunum Lbs 1381-1401 4to og finnast hér drög að mörgum hinum prentuðu ritum hans.</p></note>                       
                        </msItem>  
                        <msItem n="2" defective="false" class="kvsk bok glosu">
                            <title type="supplied">Bemærkninger í versene í Guðmundarsaga</title>
                            <author key="JonTho009">Jón Þorkelsson</author>
                            <note><p>Bemærkninger til nogle steder i versene i Guðmundarsaga ved abbed Arngrim.</p></note>
                            </msItem>  
                        <msItem n="3" defective="false" class="kvsk bok glosu">
                            <title type="supplied">Bemærkninger í versene í Heimskringla</title>
                            <author key="JonTho009">Jón Þorkelsson</author>
                            <note><p>Bemærkninger til nogle steder i versene i Heimskringla.</p></note>
                        </msItem>  
                        <msItem n="4" defective="false" class="kvsk bok glosu">
                            <title type="supplied">Vísnaskýringar í Njálu</title>
                            <author key="JonTho009">Jón Þorkelsson</author>
                            <note><p>Athugasemdir við vísur í Njálu.</p></note>
                        </msItem>  
                        <msItem n="5" defective="false" class="kvsk bok glosu">
                            <title type="supplied">Aldur vísna í  Grettissögu</title>
                            <author key="JonTho009">Jón Þorkelsson</author>
                            <note><p>Aldur vísnanna í Grettissögu, á eftir fylgir Bemærkninger til adskillige Oldtidsdigte.</p></note>
                        </msItem>  
                        <msItem n="6" defective="false" class="kvad fornkv bok glosu">
                            <title type="supplied">Fornkvæði</title>
                            <note><p>Kvæði aftast í Konungsbók Snorra Eddu (Málsháttarkvæði), Dýrðlingakvæði AM 720 4 membr, Íslendingadrápa <name type="person" key="HauVal001">Hauks Valdísarsonar</name> AM 748 4, Guðm. saga góða cap 42, 
                                    Selkolluvísur <name type="person" key="EinGil001">Einars Gilssonar</name>, vísur Einars Gilssonar um viðtal Þóris erkibiskups og herra Guðmundar biskups í Guðmundar sögu góða, Ólafsríma Einars Gilssonar, kvæði <name type="person" key="EinSku001">Einars Skúlasonar</name>.</p></note>
                        </msItem>  
                        <msItem n="7" defective="false" class="kvsk bok glosu">
                            <title type="supplied">Vísurnar í Egilssögu</title>
                            <author key="HalSch001">Dr. Scheving</author>
                            <note><p>Athugasemdir Dr. Schevings við vísurnar í Egilssögu.</p></note>
                        </msItem> 
                        <msItem n="8" defective="false" class="fornkv bok glosu">
                            <title type="supplied">Kvæði Egils Skallagrímssonar</title>
                            <author key="EgiSka001">Egill Skallagrímsson</author>
                            <note><p>Ásamt latneskri þýðingu á Sonatorreki. Með hendi <name type="person" key="BenGro001">Bendikt Gröndals</name>.</p></note>
                        </msItem> 
